{
  "fields": {
    "name": {
      "type": "String",
      "description": "Room name (optional)"
    },
    "code": {
      "type": "String",
      "required": true,
      "unique": true,
      "match": "/^[0-9]{6}$/",
      "description": "6-digit room code"
    },
    "host": {
      "type": "ObjectId",
      "ref": "User",
      "required": true,
      "description": "User who created the room"
    },
    "players": {
      "type": "Object",
      "required": true,
      "properties": {
        "white": {
          "type": "Object",
          "properties": {
            "userId": {
              "type": "ObjectId",
              "ref": "User"
            },
            "socketId": {
              "type": "String"
            }
          }
        },
        "black": {
          "type": "Object",
          "properties": {
            "userId": {
              "type": "ObjectId",
              "ref": "User"
            },
            "socketId": {
              "type": "String"
            }
          }
        }
      },
      "description": "Players in the room with their active socket connections"
    },
    "gameId": {
      "type": "ObjectId",
      "ref": "Game",
      "description": "Reference to the active game"
    },
    "status": {
      "type": "String",
      "enum": ["waiting", "full", "in_game", "closed"],
      "default": "waiting"
    },
    "expiresAt": {
      "type": "Date",
      "description": "Expiration time for inactive rooms"
    }
  },
  "useFieldsFrom": ["detail"],
  "behaviors": ["generateRoomCode", "preSave"]
}