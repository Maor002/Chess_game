{
  "fields": {
    "players": {
      "type": "Object",
      "required": true,
      "properties": {
        "white": {
          "type": "ObjectId",
          "ref": "User",
          "required": true
        },
        "black": {
          "type": "ObjectId",
          "ref": "User",
          "required": true
        }
      }
    },
    "boardState": {
      "type": "String",
      "required": true,
      "description": "FEN representation of the board"
    },
    "moves": {
      "type": "Array",
      "default": [],
      "items": {
        "type": "Object",
        "properties": {
          "from": {
            "type": "String"
          },
          "to": {
            "type": "String"
          },
          "piece": {
            "type": "String"
          },
          "fenAfter": {
            "type": "String"
          },
          "timestamp": {
            "type": "Date",
            "default": "Date.now"
          }
        }
      },
      "description": "History of moves"
    },
    "turn": {
      "type": "String",
      "enum": ["white", "black"],
      "default": "white"
    },
    "status": {
      "type": "String",
      "enum": ["in_progress", "white_won", "black_won", "draw"],
      "default": "in_progress"
    },
    "winner": {
      "type": "ObjectId",
      "ref": "User",
      "description": "Winner of the game"
    }
 
},
  "useFieldsFrom": ["detail"],  
  "behaviors": ["preSave"]
}